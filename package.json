{
  "name": "kimi-partner",
  "version": "0.1.0",
  "description": "Bring Kimi's frontend implementation and visual taste into a Codex-controlled workflow.",
  "private": true,
  "license": "MIT",
  "author": "Jevon Hou",
  "homepage": "https://github.com/jevonhou/kimi-partner#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jevonhou/kimi-partner.git"
  },
  "bugs": {
    "url": "https://github.com/jevonhou/kimi-partner/issues"
  },
  "keywords": [
    "codex",
    "kimi",
    "kimi-code",
    "mcp",
    "ai-agents",
    "developer-tools"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "render:launch": "node scripts/render-launch-assets.mjs",
    "test": "node --test tests/*.test.mjs",
    "verify": "npm run build && npm test && node --check dist/mcp-server.mjs",
    "start:mcp": "npm run build && node dist/mcp-server.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "esbuild": "0.25.12",
    "zod": "4.1.13"
  }
}
